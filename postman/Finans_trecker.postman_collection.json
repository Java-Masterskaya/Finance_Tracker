    {
      "name": "8. Add transaction",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "if(!pm.collectionVariables.get(\"last_category_id\")) {",
              "    pm.collectionVariables.set(\"last_category_id\", 1);",
              "}",
              "// Получаем текущую дату и время в формате ISO (например, 2026-06-26T11:15:21.123Z)",
              "const isoString = new Date().toISOString();",
              "",
              "// Отрезаем точку и миллисекунды, оставляя только секунды и добавляя Z",
              "// Результат: 2026-06-26T11:15:21Z",
              "const formattedDate = isoString.split('.')[0] + 'Z';",
              "",
              "// Записываем полученную строку в переменную окружения Postman",
              "pm.environment.set(\"current_date_strict\", formattedDate);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Транзакция успешно создана\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "if (pm.response.code === 201) {",
              "    var jsonData = pm.response.json();",
              "    pm.collectionVariables.set(\"last_transaction_id\", jsonData.transactionId);",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "{{jwt_token}}",
            "type": "text"
          },
          {
            "key": "X-Idempotency-Key",
            "value": "{{$randomUUID}}",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"accountId\": {{last_account_id}},\n  \"type\": \"EXPENSE\",\n  \"amount\": 1500.0,\n  \"categoryId\": {{last_category_id}},\n  \"currency\": \"RUB\",\n  \"date\": \"{{current_date_strict}}\",\n  \"description\": \"Покупка продуктов\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/api/v1/transactions",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "transactions"
          ]
        }
      },
      "response": []
