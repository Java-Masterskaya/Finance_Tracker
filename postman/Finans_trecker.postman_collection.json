              "pm.test(\"Счет успешно создан\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "if (pm.response.code === 201 && pm.response.text()) {",
              "    var jsonData = pm.response.json();",
              "    if (jsonData.id) {",
              "        pm.collectionVariables.set(\"last_account_id\", jsonData.id);",
              "        console.log(\"ID нового счета сохранен: \" + jsonData.id);",
              "    }",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
